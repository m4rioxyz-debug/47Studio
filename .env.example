# Discord Bot Credentials
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Server Configuration
PORT=3000

# GitHub Webhook Security
# Recommended to secure your webhook. Create a random string and set it here and in GitHub Webhook settings.
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# Notification Customization
# You can use '@everyone', '@here', or a specific Role ID like '<@&123456789012345678>' to tag people when a push occurs.
ROLE_TO_TAG=@everyone
